    "prebuild": "pnpm check-env",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed2.js",
    "db:studio": "prisma studio",
    "check-env": "tsx scripts/check-env.ts",
    "check-env:prod": "cross-env NODE_ENV=production tsx scripts/check-env.ts",
    "db:backup": "tsx scripts/backup.ts",
    "db:backup:sql": "bash -c 'source .env && mysqldump -h $(echo $DATABASE_URL | sed -E \"s|.*@([^:/]+):.*|\\1|\") -P $(echo $DATABASE_URL | sed -E \"s|.*:([0-9]+)/.*|\\1|\") -u $(echo $DATABASE_URL | sed -E \"s|.*//([^:]+):.*|\\1|\") -p$(echo $DATABASE_URL | sed -E \"s|.*//[^:]+:([^@]+)@.*|\\1|\") $(echo $DATABASE_URL | sed -E \"s|.*/([^?]+)$|\\1|\") > backup.sql'",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky install"
  },
